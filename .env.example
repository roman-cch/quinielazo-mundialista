# Plantilla de variables de entorno SOLO para pruebas locales con `netlify dev`.
# En producción NO se usa este archivo: las variables van en Netlify (Site configuration
# > Environment variables). Copia este archivo a ".env" y rellena los valores.
# IMPORTANTE: .env y los .json de credenciales están en .gitignore. Nunca los subas.

# JSON de la cuenta de servicio de Firebase, MINIFICADO EN UNA SOLA LÍNEA y entre comillas.
# (En .env no se admiten saltos de línea; pega el JSON en una línea.)
FIREBASE_SERVICE_ACCOUNT='PEGA_AQUI_EL_JSON_COMPLETO_EN_UNA_SOLA_LINEA'

# URL de la Realtime Database
FIREBASE_DB_URL=https://quinielazo-mundialista-default-rtdb.europe-west1.firebasedatabase.app

# Token de football-data.org (gratuito; su capa free SÍ incluye el Mundial)
FOOTBALLDATA_TOKEN=tu_token_aqui
FOOTBALLDATA_COMP=WC

# Secreto de un solo uso para lanzar la provisión inicial de jugadores
SETUP_SECRET=inventate_una_frase_secreta
